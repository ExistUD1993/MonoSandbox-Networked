<?xml version="1.0" encoding="utf-8" ?>
<Project>
	<Target Name="CopyToPlugins" AfterTargets="Build" Condition="'$(CI)'!='TRUE' and '$(PluginsPath)' != '' and Exists('$(PluginsPath)')">
		<Copy SourceFiles="$(TargetPath)" DestinationFolder="$(PluginsPath)" />
		<Message Text="Copied to Plugins" Importance="high"/>
	</Target>
</Project>
